# 箱 Hako Configuration
# Every knob is listed below. Uncomment to change.
# Last-wins: later values override earlier ones.

# ============================================================
#  Editor basics
# ============================================================

# Tab width in columns.
tab_stop=4

# 1 = real tab char. 0 = expand tabs to spaces.
use_tabs=1

# 1 = soft-wrap long lines. 0 = horizontal scroll.
word_wrap=1

# 0=off, 1=absolute, 2=relative.
show_line_numbers=1

# Undo stack depth.
max_undo_levels=100

# Match previous line's indent when opening a new line.
auto_indent=1

# Add one indent level after '{', ':', etc.
smart_indent=1

# Mouse click-to-position + scroll wheel.
mouse_enabled=1

# Lines per mouse-wheel tick.
scroll_speed=3

# ============================================================
#  紙 Kami — file explorer (left panel)
# ============================================================

# Show explorer panel at startup.
explorer_enabled=1

# Panel width in columns (10-60).
explorer_width=30

# Show dotfiles in explorer.
explorer_show_hidden=0

# ============================================================
#  零 Rei — AI assistant (right panel)
# ============================================================

# Provider: ollama | anthropic | openai
# (anthropic also accepts 'claude', openai also accepts 'gpt' or 'groq')
ai_provider=ollama

# API key. Leave blank for ollama (local).
ai_api_key=

# Endpoint root (scheme + host). Paths appended per provider.
#   ollama    -> http://localhost:11434
#   anthropic -> https://api.anthropic.com
#   openai    -> https://api.openai.com
#   groq      -> https://api.groq.com/openai
ai_endpoint=http://localhost:11434

# Model id.
#   ollama    -> llama3.2, codellama, mistral, qwen2.5-coder, ...
#   anthropic -> claude-sonnet-4-20250514, claude-opus-4-20250514, ...
#   openai    -> gpt-4o-mini, gpt-4o, o1-mini, ...
#   groq      -> llama-3.1-70b-versatile, mixtral-8x7b-32768, ...
ai_model=llama3.2

# Max tokens per response.
ai_max_tokens=2048

# Function-calling / tool loop (Anthropic only for now).
# 1 = read_file/list_dir/run_shell available to the model.
ai_tools_enabled=1

# SSE token streaming. Auto-disabled when tools are on.
ai_stream=1

# Mascot ASCII art file. Blank = built-in lucky cat.
# Example: ai_mascot=~/.hako/mascots/neko.txt
ai_mascot=

# ============================================================
#  Theme preset
# ============================================================
# Dark:  dark, gruvbox, nord, dracula, monokai, solarized,
#        tokyonight, catppuccin, onedark, material,
#        everforest, rosepine, github-dark, ayu, kanagawa
# Light: light, github-light
theme=gruvbox

# ============================================================
#  Custom colors (RGB 0-255). Override preset values.
# ============================================================

# Surfaces
# theme_bg=30,30,30
# theme_fg=212,212,212

# Syntax
# theme_comment=106,153,85
# theme_keyword1=86,156,214
# theme_keyword2=78,201,176
# theme_string=206,145,120
# theme_number=181,206,168

# Chrome
# theme_line_number=133,133,133
# theme_status_bg=50,50,50
# theme_status_fg=212,212,212
# theme_border=80,80,80
# theme_visual_bg=38,79,120
# theme_visual_fg=255,255,255

# ============================================================
#  Starter combos — uncomment one block
# ============================================================

# --- Prose ---
# theme=github-light
# show_line_numbers=0
# word_wrap=1
# explorer_enabled=0

# --- Keyboard-only C ---
# theme=gruvbox
# tab_stop=4
# show_line_numbers=2
# mouse_enabled=0

